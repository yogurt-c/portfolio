generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  title     String
  period    String   @default("") // 예: "2024.01 ~ 2025.03"
  desc      String
  body      String   @default("") // Tiptap HTML
  image     String   @default("")
  tags      String[] @default([])
  links     Json     @default("[]") // { label, url }[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

model Profile {
  id       Int    @id @default(1)
  name     String
  role     String
  bio      String
  email    String
  github   String
  location String
}

// MCP 클라이언트별 API 토큰. 평문은 발급 시점에만 노출되고 DB 엔 hash 만 저장.
model McpToken {
  id         String    @id @default(cuid())
  label      String
  hash       String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([revokedAt])
}
