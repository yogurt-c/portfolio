generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  title     String
  year      Int
  desc      String
  body      String   @default("") // Tiptap HTML
  image     String   @default("")
  tags      String[] @default([])
  links     Json     @default("[]") // { label, url }[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

model Profile {
  id       Int    @id @default(1)
  name     String
  role     String
  bio      String
  email    String
  github   String
  location String
}
